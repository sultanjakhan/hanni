{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hanni",
  "version": "0.61.0",
  "identifier": "com.sultanjakhan.hanni",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hanni",
        "width": 760,
        "height": 720,
        "minWidth": 640,
        "minHeight": 500,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob: https://api.qrserver.com; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:8234 http://127.0.0.1:8235 http://127.0.0.1:8236 http://127.0.0.1:8237 http://127.0.0.1:8239 http://127.0.0.1:8240; media-src 'self' blob:; worker-src 'self' blob:; font-src 'self'; object-src 'none'; frame-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "resources": ["libs/darwin-aarch64/crsqlite.dylib"],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://gist.githubusercontent.com/sultanjakhan/19c45003936df5c74d7c0af5a86f8b9b/raw/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ4OUM1QzNGQTI1QjZEMTgKUldRWWJWdWlQMXljMkdjQUNSMzBNbWVXeVYrZCtYekt0Y1V4dmg5UnVFSXBraUpoUUt5WURkWlMK"
    }
  }
}
