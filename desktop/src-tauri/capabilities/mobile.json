{
  "identifier": "mobile",
  "description": "Capability for Android",
  "platforms": ["android", "iOS"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "process:default",
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-create",
      "allow": [{ "path": "$HOME/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$HOME/**" }]
    },
    "fs:allow-rename",
    "fs:allow-remove"
  ]
}
