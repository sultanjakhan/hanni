rules_version = '2';

// Hanni share-link cloud mirror — Stage C-1.
//
// Auth model: token in URL is the secret. Same trust assumption as the local
// axum tunnel — anyone with the link can read the data, no Firebase Auth
// required. This avoids needing Cloud Functions to mint custom JWTs (Spark
// plan friendly). All writes are deny — Hanni mirrors via Admin SDK
// (service-account JWT) which bypasses these rules.
//
// Stage C-2 will add guest writes (still token-as-secret), and C-3 may
// migrate to anonymous Auth + custom claims for proper isolation.

service cloud.firestore {
  match /databases/{database}/documents {

    // share_links/{token} — top-level doc + every sub-collection (recipes,
    // products, ingredient_catalog, food_blacklist, meal_plan,
    // recipe_ingredients) is publicly readable to anyone who knows the
    // token. Writes are denied: Hanni's mirror loop uses the service
    // account, which bypasses rules anyway.
    match /share_links/{token}/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Activity log — neither read nor write from clients.
    match /activity/{id} {
      allow read, write: if false;
    }

    // owners/{uid}/... — Stage D owner-side sync. Each user can read/write
    // documents under their own owner_uid (matches Firebase Auth uid from
    // Sign-in-with-Google). No cross-user access.
    match /owners/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
